<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
	<name>PLG_SYSTEM_RA_TWEAKS</name>
	<author>East Cheshire Ramblers</author>
	<creationDate>2026-06-27</creationDate>
	<copyright>Copyright (C) East Cheshire Ramblers. All rights reserved.</copyright>
	<license>GNU General Public License version 3 or later; see LICENSE.txt</license>
	<authorEmail>webmaster@bigley.me.uk</authorEmail>
	<authorUrl>https://ramblerseastcheshire.org.uk/</authorUrl>
	<version>1.2.0</version>
	<description>PLG_SYSTEM_RA_TWEAKS_XML_DESCRIPTION</description>
	<namespace path="src">Ramblerseastcheshire\Plugin\System\RaTweaks</namespace>
	<files>
		<folder plugin="ra_tweaks">services</folder>
		<folder>src</folder>
		<folder>language</folder>
	</files>
	<languages>
		<language tag="en-GB">language/en-GB/plg_system_ra_tweaks.ini</language>
		<language tag="en-GB">language/en-GB/plg_system_ra_tweaks.sys.ini</language>
	</languages>
	<updateservers>
		<server type="extension" priority="1" name="RA Tweaks Updates">https://raw.githubusercontent.com/East-Cheshire-Ramblers/ra_tweaks/main/updates/ra_tweaks.xml</server>
	</updateservers>
	<config>
		<fields name="params">
			<fieldset
				name="changed_walk_highlighting"
				label="PLG_SYSTEM_RA_TWEAKS_FIELDSET_CHANGED_WALK_HIGHLIGHTING_LABEL"
				description="PLG_SYSTEM_RA_TWEAKS_FIELDSET_CHANGED_WALK_HIGHLIGHTING_DESC"
			>
				<field
					name="changed_walk_highlighting_intro"
					type="spacer"
					label="PLG_SYSTEM_RA_TWEAKS_FIELDSET_CHANGED_WALK_HIGHLIGHTING_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELDSET_CHANGED_WALK_HIGHLIGHTING_DESC"
					class="text"
				/>
				<field
					name="marker"
					type="text"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_MARKER_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_MARKER_DESC"
					default="***"
				/>
				<field
					name="colour"
					type="color"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_COLOUR_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_COLOUR_DESC"
					default="#F08050"
				/>
				<field
					name="cancel_terms"
					type="text"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_CANCEL_TERMS_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_CANCEL_TERMS_DESC"
					default="cancelled,canceled"
				/>
			</fieldset>
			<fieldset
				name="walk_type_labelling"
				label="PLG_SYSTEM_RA_TWEAKS_FIELDSET_WALK_TYPE_LABELLING_LABEL"
				description="PLG_SYSTEM_RA_TWEAKS_FIELDSET_WALK_TYPE_LABELLING_DESC"
			>
				<field
					name="walk_type_labelling_intro"
					type="spacer"
					label="PLG_SYSTEM_RA_TWEAKS_FIELDSET_WALK_TYPE_LABELLING_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELDSET_WALK_TYPE_LABELLING_DESC"
					class="text"
				/>
				<field
					name="walk_type_labels"
					type="radio"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_WALK_TYPE_LABELS_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_WALK_TYPE_LABELS_DESC"
					layout="joomla.form.field.radio.switcher"
					default="1"
					filter="integer"
				>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field
					name="stroller_max"
					type="text"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_STROLLER_MAX_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_STROLLER_MAX_DESC"
					default="4"
				/>
				<field
					name="stroller_colour"
					type="color"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_STROLLER_COLOUR_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_STROLLER_COLOUR_DESC"
					default="#4CAF50"
				/>
				<field
					name="short_max"
					type="text"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_SHORT_MAX_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_SHORT_MAX_DESC"
					default="7.9"
				/>
				<field
					name="short_colour"
					type="color"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_SHORT_COLOUR_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_SHORT_COLOUR_DESC"
					default="#2196F3"
				/>
				<field
					name="medium_max"
					type="text"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_MEDIUM_MAX_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_MEDIUM_MAX_DESC"
					default="10.9"
				/>
				<field
					name="medium_colour"
					type="color"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_MEDIUM_COLOUR_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_MEDIUM_COLOUR_DESC"
					default="#FF9800"
				/>
				<field
					name="long_colour"
					type="color"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_LONG_COLOUR_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_LONG_COLOUR_DESC"
					default="#E53935"
				/>
			</fieldset>
			<fieldset
				name="miscellaneous_tweaks"
				label="PLG_SYSTEM_RA_TWEAKS_FIELDSET_MISC_TWEAKS_LABEL"
				description="PLG_SYSTEM_RA_TWEAKS_FIELDSET_MISC_TWEAKS_DESC"
			>
				<field
					name="miscellaneous_tweaks_intro"
					type="spacer"
					label="PLG_SYSTEM_RA_TWEAKS_FIELDSET_MISC_TWEAKS_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELDSET_MISC_TWEAKS_DESC"
					class="text"
				/>
				<field
					name="align_grade_icons"
					type="radio"
					label="PLG_SYSTEM_RA_TWEAKS_FIELD_ALIGN_GRADE_ICONS_LABEL"
					description="PLG_SYSTEM_RA_TWEAKS_FIELD_ALIGN_GRADE_ICONS_DESC"
					layout="joomla.form.field.radio.switcher"
					default="1"
					filter="integer"
				>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
			</fieldset>
		</fields>
	</config>
</extension>
